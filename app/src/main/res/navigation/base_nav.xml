<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@id/homeFragment">

    <!-- Home fragment (login ekran) -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.mobilnaaplikacija.fragments.login.HomeFragment"
        android:label="Login"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_registerFragment"
            app:destination="@id/nav_register" />
    </fragment>

    <!-- Main fragment sa Drawer-om -->
    <fragment
        android:id="@+id/mainFragment"
        android:name="com.example.mobilnaaplikacija.fragments.home.HomePageFragment"
        android:label="Početna"
        tools:layout="@layout/fragment_home_page" />
    <fragment
        android:id="@+id/profile_page"
        android:name="com.example.mobilnaaplikacija.fragments.user.UserProfileFragment"
        android:label="Profil"
        tools:layout="@layout/fragment_user_profile"/>
    <fragment
        android:id="@+id/nav_register"
        android:name="com.example.mobilnaaplikacija.fragments.registration.RegisterFragment"
        android:label="Registracija"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>
    <fragment
        android:id="@+id/statistics_page"
        android:name="com.example.mobilnaaplikacija.fragments.user.StatisticsFragment"
        android:label="Statistika"
        tools:layout="@layout/fragment_statistics" >
    </fragment>
    <fragment
        android:id="@+id/shopFragment"
        android:name="com.example.mobilnaaplikacija.fragments.shop.ShopFragment"
        android:label="Prodavnica"
        tools:layout="@layout/fragment_shop" />
    <fragment
        android:id="@+id/friendsFragment"
        android:name="com.example.mobilnaaplikacija.fragments.friends.FriendsFragment"
        android:label="Prijatelji"
        tools:layout="@layout/fragment_friends" >
        <action
            android:id="@+id/action_friendsFragment_to_friendProfileFragment"
            app:destination="@id/friendProfileFragment" />
    </fragment>
    <fragment
        android:id="@+id/friendProfileFragment"
        android:name="com.example.mobilnaaplikacija.fragments.friends.FriendProfileFragment"
        android:label="Profil prijatelja"
        tools:layout="@layout/fragment_friend_profile"/>
    <fragment
        android:id="@+id/myAllianceFragment"
        android:name="com.example.mobilnaaplikacija.fragments.alliance.MyAllianceFragment"
        android:label="Moj savez"
        tools:layout="@layout/fragment_my_alliance" >
        <action
            android:id="@+id/action_myAllianceFragment_to_allianceChatFragment"
            app:destination="@id/allianceChatFragment" />
    </fragment>
    <fragment
        android:id="@+id/allianceChatFragment"
        android:name="com.example.mobilnaaplikacija.fragments.alliance.AllianceChatFragment"
        android:label="Savez Chat"
        tools:layout="@layout/fragment_alliance_chat" />
    <fragment
        android:id="@+id/categoriesFragment"
        android:name="com.example.mobilnaaplikacija.fragments.category.CategoryListFragment"
        android:label="Kategorije" />

</navigation>
