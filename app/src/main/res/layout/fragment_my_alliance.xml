<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_alliance_root"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/white">

    <!-- Gornji deo sa nazivom, vođom i FAB -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/textAllianceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Naziv saveza"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/fabOpenChat"
            app:layout_constraintHorizontal_bias="0"/>

        <TextView
            android:id="@+id/textAllianceLeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Vođa: "
            android:textSize="18sp"
            android:textColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/textAllianceName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/fabOpenChat"
            app:layout_constraintBottom_toBottomOf="@+id/fabOpenChat"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabOpenChat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_chat"
            android:contentDescription="Otvori chat"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/textAllianceLeader"
            android:layout_marginStart="8dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/light_gray"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <!-- Ostali elementi (lista članova, dugmad itd.) ostaju isti -->
    <TextView
        android:id="@+id/textMembersLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Članovi:"
        android:visibility="gone"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAllianceMembers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:overScrollMode="never"/>

    <TextView
        android:id="@+id/textNoAllianceMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trenutno niste član nijednog saveza"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:visibility="gone"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"/>

    <LinearLayout
        android:id="@+id/layoutAllianceButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:weightSum="3">

        <Button
            android:id="@+id/btnDeleteAlliance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:visibility="gone"
            android:text="Obriši savez"
            android:backgroundTint="@color/red"
            android:textColor="@color/white"
            android:padding="12dp"/>

        <Button
            android:id="@+id/btnAddMembers"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:visibility="gone"
            android:text="Dodaj članove"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:padding="12dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnLeaveAlliance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:visibility="gone"
            android:text="Napusti savez"
            android:textColor="@android:color/white"
            android:background="#D32F2F"
            android:padding="12dp"/>
    </LinearLayout>


</LinearLayout>
