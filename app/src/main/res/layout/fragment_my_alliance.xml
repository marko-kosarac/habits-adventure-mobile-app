<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_alliance_root"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/white">

    <!-- Naziv saveza -->
    <TextView
        android:id="@+id/textAllianceName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Naziv saveza"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:paddingBottom="8dp"/>

    <!-- Vođa saveza -->
    <TextView
        android:id="@+id/textAllianceLeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vođa: "
        android:textSize="18sp"
        android:textColor="@color/black"
        android:paddingBottom="16dp"/>

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/light_gray"
        android:layout_marginBottom="8dp"/>

    <!-- Lista članova -->
    <TextView
        android:id="@+id/textMembersLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Članovi:"
        android:visibility="gone"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAllianceMembers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:overScrollMode="never"/>
    <TextView
        android:id="@+id/textNoAllianceMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trenutno niste član nijednog saveza"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:visibility="gone"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"/>
    <Button
        android:id="@+id/btnDeleteAlliance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:text="Obriši savez"
        android:backgroundTint="@color/red"
        android:textColor="@color/white"
        android:padding="12dp"
        android:layout_gravity="center_horizontal"/>
    <Button
        android:id="@+id/btnLeaveAlliance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:text="Napusti savez"
        android:textColor="@android:color/white"
        android:background="#D32F2F"
        android:layout_marginTop="8dp"/>

</LinearLayout>
