<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/shop_item_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Naziv opreme -->
        <TextView
            android:id="@+id/shop_item_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Naziv Opreme"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- Opis opreme -->
        <TextView
            android:id="@+id/shop_item_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Opis opreme"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="6dp"
            android:maxLines="2"
            android:ellipsize="end"/>


        <TextView
            android:id="@+id/shop_item_bonus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bonus:"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginTop="6dp"
            android:textStyle="bold"/>
        <!-- Cena opreme -->
        <TextView
            android:id="@+id/shop_item_price"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cena: 100 novčića"
            android:textSize="14sp"
            android:textColor="@color/colorAccent"
            android:layout_marginTop="6dp"
            android:textStyle="bold"/>


        <!-- LinearLayout za količinu i dugme -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <!-- Polje za količinu -->
            <EditText
                android:id="@+id/shop_item_quantity"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:hint="Količina"
                android:inputType="number"
                android:padding="6dp"
                android:background="@drawable/edittext_rounded"
                android:gravity="center"/>

            <!-- Dugme za kupovinu -->
            <Button
                android:id="@+id/shop_item_buy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kupi"
                android:layout_marginStart="16dp"
                android:backgroundTint="@color/colorPrimary"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:paddingVertical="8dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
