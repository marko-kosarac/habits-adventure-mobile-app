<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".fragments.battle.BattleFragment">

    <!-- Naslov za nagrade -->
    <TextView
        android:id="@+id/tvRewardsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Moguće nagrade:"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="20sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:gravity="center"
        android:layout_marginTop="20dp"/>

    <!-- Moguće nagrade -->
    <LinearLayout
        android:id="@+id/rewardsLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/equipment_rewards_bg"
        android:elevation="3dp"
        android:paddingVertical="8dp"
        android:paddingHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvRewardsTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivCoinReward"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/ic_coin"
            android:contentDescription="Novčići"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvCoinReward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+150"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginEnd="24dp"/>

        <ImageView
            android:id="@+id/ivEquipmentReward"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_chest"
            android:layout_marginStart="12dp"
            android:contentDescription="Oprema"/>

        <TextView
            android:id="@+id/tvEquipmentReward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Oprema"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Boss HP -->
    <TextView
        android:id="@+id/tvBossHP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/rewardsLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <ProgressBar
        android:id="@+id/pbHPBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="250dp"
        android:layout_height="20dp"
        android:progressTint="@color/red"
        app:layout_constraintTop_toBottomOf="@id/tvBossHP"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="2dp" />

    <!-- Boss (idle + hit) -->
    <FrameLayout
        android:id="@+id/layoutBoss"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/pbHPBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivBossSpriteIdle"
            android:layout_width="130dp"
            android:layout_height="210dp"
            android:background="@drawable/boss_idle"
            android:contentDescription="@string/boss"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/ivBossSpriteHit"
            android:layout_width="130dp"
            android:layout_height="210dp"
            android:background="@drawable/boss_hit"
            android:scaleType="fitCenter"
            android:contentDescription="@string/boss"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Korisnik PP -->
    <TextView
        android:id="@+id/tvUserPP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/layoutBoss"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <ProgressBar
        android:id="@+id/pbPPBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="250dp"
        android:layout_height="20dp"
        android:progressTint="@color/colorAccent"
        app:layout_constraintTop_toBottomOf="@id/tvUserPP"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="2dp" />

    <!-- Pokusaji -->
    <TextView
        android:id="@+id/tvAttackCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pokušaji: 3"
        app:layout_constraintTop_toBottomOf="@id/pbPPBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Šansa -->
    <TextView
        android:id="@+id/tvAttackChance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Šansa: 70%"
        app:layout_constraintTop_toBottomOf="@id/tvAttackCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Aktivna oprema -->
    <LinearLayout
        android:id="@+id/layoutActivatedEquipment"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/equipment_rewards_bg"
        android:elevation="3dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="8dp"
        android:paddingHorizontal="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvAttackChance"
        app:layout_constraintBottom_toTopOf="@id/btnAttackBoss"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aktivirana oprema:"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:layout_marginEnd="8dp"
            android:layout_gravity="center_vertical"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="true"
            android:scrollbars="horizontal"
            android:paddingTop="4dp">
            <LinearLayout
                android:id="@+id/activatedIconsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="16dp" />
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Dugme napad -->
    <Button
        android:id="@+id/btnAttackBoss"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/attack"
        android:backgroundTint="@color/colorPrimary"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutActivatedEquipment"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
