<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Boja pozadine -->
    <solid android:color="#F0F0F0" />

    <!-- Zaobljeni uglovi -->
    <corners android:radius="16dp" />

    <!-- Unutrašnji padding / margine -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp" />

    <!-- Opcionalno: obrub -->
    <stroke
        android:width="1dp"
        android:color="#D0D0D0" />
</shape>
